{
  "name": "travel_pro",
  "version": "1.0.0",
  "description": "A production-ready Django 5 travel agency platform with multilingual support (EN, UZ, RU, IT, ES, JA), tour/hotel/MICE booking, Celery async tasks, Cloudinary media, and Tailwind CSS frontend.",
  "main": "tailwind.config.js",
  "scripts": {
    "css:build": "node node_modules/@tailwindcss/cli/dist/index.mjs -i ./tailwind_src/input.css -o ./static/css/tailwind.css --minify",
    "css:watch": "node node_modules/@tailwindcss/cli/dist/index.mjs -i ./tailwind_src/input.css -o ./static/css/tailwind.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "alpinejs": "^3.15.12"
  }
}
